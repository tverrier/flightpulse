# =============================================================================
# FlightPulse environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Reference: SETUP.md § 8 Environment Variables.
# =============================================================================

# ----- AWS -----------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bronze + Silver buckets — populate from `terraform output`
S3_RAW_BUCKET=flightpulse-raw
S3_SILVER_BUCKET=flightpulse-silver

# Glue catalog DB — `terraform output glue_db_name`
GLUE_DATABASE=flightpulse_silver

# ----- Streaming (MSK + Kafka) ---------------------------------------------
# `terraform output msk_bootstrap_brokers` — comma-separated host:port list
MSK_BOOTSTRAP=b-1.flightpulse.xxxx.kafka.us-east-1.amazonaws.com:9098
KAFKA_TOPIC_OPENSKY=opensky.states.v1

# ----- OpenSky Network (free tier) -----------------------------------------
OPENSKY_USER=your-opensky-username
OPENSKY_PASS=your-opensky-password

# ----- Snowflake -----------------------------------------------------------
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=svc_dbt
SNOWFLAKE_PASSWORD=rotate-me
SNOWFLAKE_ROLE=rl_flightpulse_transformer
SNOWFLAKE_WAREHOUSE=wh_flightpulse_xs
SNOWFLAKE_DATABASE=flightpulse_prod

# ----- Dagster Cloud -------------------------------------------------------
DAGSTER_CLOUD_AGENT_TOKEN=dagster_cloud_xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Alerting ------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxxxxxxxxxx

# ----- BTS source ----------------------------------------------------------
# Pattern: append _<YYYY>_<MM>.zip in the Airbyte connector
BTS_DOWNLOAD_URL=https://www.transtats.bts.gov/PREZIP/On_Time_Reporting_Carrier_On_Time_Performance_1987_present
